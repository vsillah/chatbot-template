# =============================================================================
# Chatbot Template — Environment Variables
# =============================================================================
# Copy this file to .env.local:   cp .env.example .env.local
# Or run the setup wizard:        npm run setup
# =============================================================================

# =============================================================================
# Supabase (Required)
# Get these from: https://supabase.com → Your Project → Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — needed for server-side database writes (chat history)
# Get from: Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# n8n Webhook (Required)
# This is the URL of your n8n chat workflow's Webhook trigger node
# =============================================================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-workflow-id

# =============================================================================
# Voice Chat — VAPI (Optional)
# Leave empty if you don't need voice chat
# Get these from: https://vapi.ai → Dashboard
# =============================================================================
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
